<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Framework\App\FrontController">
        <plugin name="ip_rate_limit_admin_http" type="MiniOrange\IpRestriction\Plugin\AdminHttpPlugin" sortOrder="2" />
    </type>
    
    <!-- Register CLI Commands -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="admin_ip_restriction" xsi:type="object">MiniOrange\IpRestriction\Console\Command\IpRestrictionCommand</item>
            </argument>
        </arguments>
    </type>
</config>

